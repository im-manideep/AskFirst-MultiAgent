# LLM provider: "ollama" (local, free) or "openai" (cloud, quality)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:3b
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Risk policy (see CLAUDE.md) — refunds above this amount require human approval
RISK_REFUND_THRESHOLD=50
# Max resolver revisions after rejection before escalating
MAX_REVISIONS=2
